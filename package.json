{
  "name": "maxte-carpet-panel",
  "type": "module",
  "version": "0.13.0",
  "scripts": {
    "build": "rspack build --env production --config rspack/config.ts",
    "dev": "rspack build --env development --config rspack/config.ts",
    "watch": "rspack build --env development --config rspack/config.ts --watch",
    "server": "docker compose up --build",
    "format": "biome format --write .",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "devserver": "pnpm exec rspack serve -w -m development --config rspack/config.testharness.ts",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vitest run tests/makeCells.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@grafana/data": "13.1.0",
    "@grafana/runtime": "13.1.0",
    "@grafana/ui": "13.1.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@types/tinycolor2": "^1.4.6",
    "d3": "^7.9.0",
    "d3-scale-chromatic": "^3.1.0",
    "konva": "^10.0.0",
    "react": "19.2.4",
    "react-compiler-runtime": "^19.1.0-rc.3",
    "react-dom": "19.2.4",
    "react-konva": "19.2.5",
    "react-konva-utils": "2.0.0",
    "tinycolor2": "^1.6.0",
    "use-device-pixel-ratio": "^1.1.2"
  },
  "devDependencies": {
    "@babel/types": "^7.28.2",
    "@biomejs/biome": "^2.5.1",
    "@eslint-react/eslint-plugin": "^5.0.0",
    "@eslint/js": "^9.24.0",
    "@grafana/eslint-config": "^10.0.0",
    "@grafana/tsconfig": "^2.0.0",
    "@playwright/test": "^1.61.1",
    "@rspack/cli": "^1.7.12",
    "@rspack/core": "^1.7.12",
    "@stylistic/eslint-plugin": "^5.0.0",
    "@types/d3": "^7.4.3",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/node": "^20.8.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^19.0.0-beta-af1b7da-20250417",
    "consola": "^3.4.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-jsdoc": "^50.4.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-webpack-plugin": "^6.0.0",
    "happy-dom": "^20.10.6",
    "react-compiler-webpack": "^1.0.0",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "style-loader": "^4.0.0",
    "ts-checker-rspack-plugin": "^1.4.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
